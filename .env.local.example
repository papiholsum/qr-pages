# Copy this file to .env.local and fill in the values from your Supabase project's
# Settings → API page. Both are safe to expose in the browser (they're scoped by RLS).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL — used to build redirect URLs for OAuth.
# Locally this is http://localhost:3000; on Vercel set it to your deployment URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
